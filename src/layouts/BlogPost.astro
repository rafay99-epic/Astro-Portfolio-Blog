---
import { getImage } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BlogPostArticle from "@astro/blog/post/BlogPostArticle.astro";
import BlogPostBelowContent from "@astro/blog/post/BlogPostBelowContent.astro";
import BlogPostClientScript from "@astro/blog/post/BlogPostClientScript.astro";
import BlogPostHead from "@astro/blog/post/BlogPostHead.astro";
import BlogPostHeader from "@astro/blog/post/BlogPostHeader.astro";
import BlogPostRightRail from "@astro/blog/post/BlogPostRightRail.astro";
import Footer from "@astro/footer/Footer.astro";
import Header from "@astro/header/Header.astro";
import { featureFlags } from "@config/featureFlag/featureFlag.json";
import MermaidRenderer from "@react/blog/enhancements/diagram-renderer/MermaidRenderer";
import { getImagePath } from "astro-opengraph-images";

export const prerender = true;

const { url, site } = Astro;
const openGraphImageUrl = getImagePath({ url, site });

const pageUrl = Astro.url.href;
type Props = CollectionEntry<"blog">["data"] & {
	isArchive?: boolean;
	headings?: import("astro").MarkdownHeading[];
};
const isArchive = (Astro.props as Props).isArchive === true;

try {
	if (!featureFlags.showBlog) {
		return Astro.redirect("/access-denied");
	}
} catch (_error) {
	return Astro.redirect("/404");
}

const BlogPosts = featureFlags.showBlog
	? (await getCollection("blog"))
			.filter(
				(post: CollectionEntry<"blog">) =>
					!post.data.draft &&
					(isArchive ? post.data.archived : !post.data.archived),
			)
			.sort(
				(a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
					a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
			)
	: [];

const currentSlug = Astro.url.pathname.split("/").filter(Boolean).pop();
const currentBlog = BlogPosts.find(
	(post: CollectionEntry<"blog">) => post.id === currentSlug,
);

if (!currentBlog) {
	return Astro.redirect("/access-denied");
}

const currentIndex = BlogPosts.findIndex(
	(post: CollectionEntry<"blog">) => post.id === currentSlug,
);
const prevPost = currentIndex > 0 ? BlogPosts[currentIndex - 1] : undefined;
const nextPost =
	currentIndex >= 0 && currentIndex < BlogPosts.length - 1
		? BlogPosts[currentIndex + 1]
		: undefined;

const blogContent = currentBlog.body;

const {
	title,
	description,
	pubDate,
	heroImage,
	authorName,
	authorAvatar,
	tags,
	readTime,
	keywords,
	canonicalUrl,
	featured,
	excerpt,
	headings: tocHeadings = [],
} = Astro.props as Props;
const lead = excerpt || description;

let articleHeroBackgroundSrc: string | null = null;
if (heroImage) {
	try {
		const optimized = await getImage({
			src: heroImage,
			width: 1600,
			height: 900,
			format: "webp",
			quality: 72,
		});
		articleHeroBackgroundSrc = optimized.src;
	} catch {
		articleHeroBackgroundSrc = heroImage;
	}
}
const tocEntries = tocHeadings.filter(
	(h: import("astro").MarkdownHeading) => h.depth === 2 || h.depth === 3,
);
const wordCount = blogContent
	? blogContent.trim().split(/\s+/).filter(Boolean).length
	: 0;
const formattedWordCount =
	wordCount > 0 ? new Intl.NumberFormat("en-US").format(wordCount) : "";
const markdownDate = pubDate.toISOString().slice(0, 10);
const markdownBody = blogContent?.trim() || "";
const markdownPayload = [
	`# ${title}`,
	"",
	`Source: ${pageUrl}`,
	`Published: ${markdownDate}`,
	"",
	...(lead ? [lead, ""] : []),
	"---",
	"",
	markdownBody,
	"",
].join("\n");
const postActionPayload = JSON.stringify({
	title,
	url: pageUrl,
	markdown: markdownPayload,
}).replace(/</g, "\\u003c");

const updatedDate = currentBlog.data.updatedDate;
---

<html lang="en">
  <head>
    <BlogPostHead
      title={title}
      description={description}
      heroImage={heroImage}
      keywords={keywords}
      pageUrl={pageUrl}
      openGraphImageUrl={openGraphImageUrl}
      pubDate={pubDate}
      authorName={authorName}
      authorAvatar={authorAvatar}
      tags={tags}
      readTime={readTime}
      blogContent={blogContent}
      updatedDate={updatedDate}
      featured={featured}
      excerpt={excerpt}
      canonicalUrl={canonicalUrl}
    />
  </head>
  <body class="blog-container" style="overflow-x: hidden; overflow-y: auto;">
    <Header />

    <main class="main-content relative z-10 flex flex-1 flex-col">
      <section class="post-shell">
        <div
          class:list={[
            "post-header-hero",
            articleHeroBackgroundSrc
              ? "post-header-hero--has-image"
              : "post-header-hero--plain",
          ]}
        >
          {
            articleHeroBackgroundSrc && (
              <>
                <div class="post-header-hero__blur-wrap" aria-hidden="true">
                  <img
                    src={articleHeroBackgroundSrc}
                    alt=""
                    width={1600}
                    height={900}
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                    class="post-header-hero__blur-img"
                  />
                </div>
                <div class="post-header-hero__scrim" aria-hidden="true" />
              </>
            )
          }
          <div class="post-header-hero__inner">
            <BlogPostHeader
              title={title}
              lead={lead}
              pubDate={pubDate}
              isArchive={isArchive}
              authorName={authorName}
              authorAvatar={authorAvatar}
              readTime={readTime}
              wordCount={wordCount}
              formattedWordCount={formattedWordCount}
              tags={tags}
              updatedDate={updatedDate}
            />
          </div>
        </div>

        <div class="post-grid">
          <BlogPostArticle>
            <slot />
          </BlogPostArticle>

          <BlogPostRightRail
            tocEntries={tocEntries}
            isArchive={isArchive}
            pageUrl={pageUrl}
          />
        </div>
      </section>

      {!isArchive ? <MermaidRenderer client:load /> : null}

      <BlogPostBelowContent
        isArchive={isArchive}
        currentSlug={currentSlug || ""}
        BlogPosts={BlogPosts}
        prevPost={prevPost}
        nextPost={nextPost}
      />
    </main>

    <BlogPostClientScript postActionPayload={postActionPayload} />
    <Footer />
  </body>
</html>
