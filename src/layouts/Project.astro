---
import BaseHead from "@astro/base/BaseHead.astro";
import Footer from "@astro/footer/Footer.astro";
import Header from "@astro/header/Header.astro";
import ProjectBodySection from "@astro/projects/ProjectBodySection.astro";
import ProjectClientScript from "@astro/projects/ProjectClientScript.astro";
import ProjectHero from "@astro/projects/ProjectHero.astro";
import ProjectPageStyles from "@astro/projects/ProjectPageStyles.astro";
import { featureFlags } from "@config/featureFlag/featureFlag.json";
import CodeCopySimple from "@react/blog/enhancements/code-copy/CodeCopySimple";
import MermaidRenderer from "@react/blog/enhancements/diagram-renderer/MermaidRenderer";

const pageUrl = Astro.url.href;
export const prerender = true;

type Props = {
	Projecttitle: string;
	ProjectDescription: string;
	ProjectTech?: string[];
	ProjectImage?: string;
	ProjectGithubLink?: string;
	ProjectDeployedLink?: string;
	ProjectCategory?: string[];
	ProjectRanking?: string;
};

const {
	Projecttitle,
	ProjectDescription,
	ProjectTech,
	ProjectImage,
	ProjectGithubLink,
	ProjectDeployedLink,
	ProjectCategory,
	ProjectRanking,
} = Astro.props as Props;

const primaryCategory = ProjectCategory?.[0];
const stackCount = ProjectTech?.length ?? 0;

try {
	if (!featureFlags.showProjects) {
		return Astro.redirect("/access-denied");
	}
} catch (_error) {
	return Astro.redirect("/404");
}
---

<html lang="en">
	<head>
		<BaseHead title={Projecttitle} description={ProjectDescription} />
		<ProjectPageStyles />
	</head>

	<body class="project-container" style="overflow-x: hidden; overflow-y: auto;">
		<Header />

		<main class="project-shell">
			<ProjectHero
				Projecttitle={Projecttitle}
				ProjectDescription={ProjectDescription}
				ProjectTech={ProjectTech}
				ProjectImage={ProjectImage}
				ProjectGithubLink={ProjectGithubLink}
				ProjectDeployedLink={ProjectDeployedLink}
				ProjectCategory={ProjectCategory}
				ProjectRanking={ProjectRanking}
			/>

			<ProjectBodySection
				pageUrl={pageUrl}
				primaryCategory={primaryCategory}
				ProjectRanking={ProjectRanking}
				stackCount={stackCount}
				ProjectDeployedLink={ProjectDeployedLink}
				ProjectGithubLink={ProjectGithubLink}
				ProjectTech={ProjectTech}
			>
				<slot />
			</ProjectBodySection>
		</main>

		<MermaidRenderer client:load />
		<CodeCopySimple client:visible />

		<ProjectClientScript />

		<Footer />
	</body>
</html>
