---
import BaseHead from "@astro/base/BaseHead.astro";
import ContentContainer from "@astro/blog/layout/ContentContainer.astro";
import Footer from "@astro/footer/Footer.astro";
import Header from "@astro/header/Header.astro";
import LegalPageHeader from "@astro/legal/LegalPageHeader.astro";
import LegalPageStyles from "@astro/legal/LegalPageStyles.astro";
import authorConfig from "@config/siteConfig/info.json";

export const prerender = true;

interface Props {
	title: string;
	description: string;
	lastUpdated?: Date;
}

const { title, description, lastUpdated } = Astro.props;

const formattedUpdated = lastUpdated
	? new Intl.DateTimeFormat("en-US", {
			year: "numeric",
			month: "long",
			day: "numeric",
		}).format(lastUpdated)
	: null;
---

<html lang="en">
	<head>
		<BaseHead
			title={`${title} | ${authorConfig.SiteName}`}
			description={description}
		/>
		<LegalPageStyles />
	</head>

	<body class="legal-container">
		<Header />

		<main class="mx-auto w-full max-w-7xl px-4 pb-16 pt-20">
			<LegalPageHeader
				title={title}
				description={description}
				formattedUpdated={formattedUpdated}
				lastUpdated={lastUpdated}
			/>

			<ContentContainer withBackground={true} class="content-prose">
				<slot />
			</ContentContainer>
		</main>

		<Footer class="mt-auto" />
	</body>
</html>
