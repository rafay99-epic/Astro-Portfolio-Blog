---
/**
 * SeriesBadge — compact pill shown on blog cards and list items.
 *
 * Usage:
 *   <SeriesBadge series="Building a SaaS" part={2} total={5} />
 */

interface Props {
	/** Human-readable series name. */
	series: string;
	/** Which part this post is (1-based). */
	part: number;
	/** Total parts in the series (declared or inferred). */
	total?: number | undefined;
	/** When true, render a minimal "Part N" chip. */
	compact?: boolean | undefined;
}

import { toSeriesSlug } from "@util/series";

const { series, part, total, compact = false } = Astro.props;
const seriesSlug = toSeriesSlug(series);
const href = `/blog/series/${seriesSlug}`;
---

{
	compact ? (
		<a href={href} class="series-badge-compact" title={`Part of series: ${series}`}>
			<svg
				class="series-badge-icon"
				width="12"
				height="12"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20" />
			</svg>
			<span>Part {part}{total ? `/${total}` : ""}</span>
		</a>
	) : (
		<a href={href} class="series-badge" title={`View all parts of "${series}"`}>
			<svg
				class="series-badge-icon"
				width="14"
				height="14"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20" />
			</svg>
			<span class="series-badge-label">{series}</span>
			<span class="series-badge-part">Part {part}{total ? ` of ${total}` : ""}</span>
		</a>
	)
}

<style>
	/* ─── Full Badge ─── */
	.series-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.25rem 0.7rem;
		border-radius: 999px;
		border: 1px solid rgba(187, 154, 247, 0.25);
		background: rgba(187, 154, 247, 0.08);
		font-size: 0.75rem;
		line-height: 1.4;
		color: #bb9af7;
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease;
		white-space: nowrap;
	}

	.series-badge:hover {
		border-color: rgba(187, 154, 247, 0.5);
		background: rgba(187, 154, 247, 0.14);
	}

	.series-badge-icon {
		flex-shrink: 0;
		opacity: 0.7;
	}

	.series-badge-label {
		font-weight: 600;
		max-width: 16ch;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.series-badge-part {
		opacity: 0.7;
		font-variant-numeric: tabular-nums;
	}

	/* ─── Compact Badge ─── */
	.series-badge-compact {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.15rem 0.5rem;
		border-radius: 999px;
		border: 1px solid rgba(187, 154, 247, 0.2);
		background: rgba(187, 154, 247, 0.06);
		font-size: 0.7rem;
		line-height: 1.3;
		color: #bb9af7;
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease;
		white-space: nowrap;
	}

	.series-badge-compact:hover {
		border-color: rgba(187, 154, 247, 0.45);
		background: rgba(187, 154, 247, 0.12);
	}
</style>
