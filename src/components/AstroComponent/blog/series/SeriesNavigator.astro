---
/**
 * SeriesNavigator — renders an in-article series timeline with progress.
 *
 * Placed inside the blog post layout, above the article content.
 * Shows all parts of the series with the current post highlighted,
 * plus prev/next navigation buttons.
 */

import type { SeriesContext } from "types/series";

interface Props {
	context: SeriesContext;
}

const { context } = Astro.props;
const { name, slug, posts, totalParts, currentIndex } = context;

const prevPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
const nextPost =
	currentIndex >= 0 && currentIndex < posts.length - 1
		? posts[currentIndex + 1]
		: undefined;

const progressPercent = Math.round(((currentIndex + 1) / totalParts) * 100);
---

<aside class="series-nav" aria-label={`Series: ${name}`}>
	<!-- Header -->
	<div class="series-nav-header">
		<div class="series-nav-label">
			<svg
				width="16"
				height="16"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20" />
			</svg>
			<span>Series</span>
		</div>
		<a href={`/blog/series/${slug}`} class="series-nav-title">
			{name}
		</a>
	</div>

	<!-- Progress bar -->
	<div class="series-nav-progress" aria-label={`Progress: ${progressPercent}%`}>
		<div class="series-nav-progress-track">
			<div
				class="series-nav-progress-fill"
				style={`width: ${progressPercent}%`}
			/>
		</div>
		<span class="series-nav-progress-text">
			Part {currentIndex + 1} of {totalParts}
		</span>
	</div>

	<!-- Parts list -->
	<details class="series-nav-parts" open={posts.length <= 6}>
		<summary class="series-nav-parts-toggle">
			<span>All parts</span>
			<svg
				class="series-nav-chevron"
				width="14"
				height="14"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="m6 9 6 6 6-6" />
			</svg>
		</summary>

		<ol class="series-nav-list">
			{posts.map((post, index) => {
				const isCurrent = index === currentIndex;
				const partNum = post.data.seriesPart;
				return (
					<li class:list={["series-nav-item", { "is-current": isCurrent }]}>
						<span class="series-nav-item-num">{partNum}</span>
						{isCurrent ? (
							<span class="series-nav-item-title is-active" aria-current="page">
								{post.data.title}
							</span>
						) : (
							<a href={`/blog/${post.id}`} class="series-nav-item-title">
								{post.data.title}
							</a>
						)}
					</li>
				);
			})}

			{/* Placeholder rows for unreleased parts */}
			{totalParts > posts.length &&
				Array.from({ length: totalParts - posts.length }, (_, i) => (
					<li class="series-nav-item is-upcoming">
						<span class="series-nav-item-num">{posts.length + i + 1}</span>
						<span class="series-nav-item-title is-placeholder">Coming soon</span>
					</li>
				))}
		</ol>
	</details>

	<!-- Prev / Next -->
	<div class="series-nav-footer">
		{prevPost ? (
			<a href={`/blog/${prevPost.id}`} class="series-nav-btn series-nav-prev">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M15 19l-7-7 7-7" />
				</svg>
				<span class="series-nav-btn-label">
					<span class="series-nav-btn-hint">Previous</span>
					<span class="series-nav-btn-title">{prevPost.data.title}</span>
				</span>
			</a>
		) : (
			<div />
		)}

		{nextPost ? (
			<a href={`/blog/${nextPost.id}`} class="series-nav-btn series-nav-next">
				<span class="series-nav-btn-label">
					<span class="series-nav-btn-hint">Next</span>
					<span class="series-nav-btn-title">{nextPost.data.title}</span>
				</span>
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M9 5l7 7-7 7" />
				</svg>
			</a>
		) : (
			<div />
		)}
	</div>
</aside>

<style>
	/* ═══════════════════════════════════════════
	   SeriesNavigator — in-article series timeline
	   ═══════════════════════════════════════════ */

	.series-nav {
		margin: 1.5rem 0 2rem;
		padding: 1.25rem 1.5rem;
		border-radius: 16px;
		border: 1px solid rgba(187, 154, 247, 0.2);
		background: rgba(36, 40, 59, 0.5);
		backdrop-filter: blur(8px);
	}

	/* ─── Header ─── */
	.series-nav-header {
		margin-bottom: 0.85rem;
	}

	.series-nav-label {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #bb9af7;
		margin-bottom: 0.3rem;
	}

	.series-nav-title {
		font-size: 1.1rem;
		font-weight: 700;
		color: #c0caf5;
		text-decoration: none;
		transition: color 0.2s ease;
		line-height: 1.3;
	}

	.series-nav-title:hover {
		color: #bb9af7;
	}

	/* ─── Progress ─── */
	.series-nav-progress {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.series-nav-progress-track {
		flex: 1;
		height: 4px;
		border-radius: 999px;
		background: rgba(86, 95, 137, 0.3);
		overflow: hidden;
	}

	.series-nav-progress-fill {
		height: 100%;
		border-radius: 999px;
		background: linear-gradient(90deg, #7aa2f7, #bb9af7);
		transition: width 0.4s ease;
	}

	.series-nav-progress-text {
		font-size: 0.75rem;
		color: #565f89;
		white-space: nowrap;
		font-variant-numeric: tabular-nums;
	}

	/* ─── Parts List ─── */
	.series-nav-parts {
		margin-bottom: 1rem;
	}

	.series-nav-parts-toggle {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.8rem;
		font-weight: 500;
		color: #a9b1d6;
		cursor: pointer;
		list-style: none;
		padding: 0.3rem 0;
		user-select: none;
	}

	.series-nav-parts-toggle::-webkit-details-marker {
		display: none;
	}

	.series-nav-chevron {
		transition: transform 0.2s ease;
	}

	.series-nav-parts[open] > .series-nav-parts-toggle .series-nav-chevron {
		transform: rotate(180deg);
	}

	.series-nav-list {
		list-style: none;
		padding: 0;
		margin: 0.5rem 0 0;
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.series-nav-item {
		display: flex;
		align-items: flex-start;
		gap: 0.6rem;
		padding: 0.4rem 0.6rem;
		border-radius: 8px;
		transition: background-color 0.15s ease;
	}

	.series-nav-item:hover {
		background: rgba(86, 95, 137, 0.1);
	}

	.series-nav-item.is-current {
		background: rgba(187, 154, 247, 0.1);
		border-left: 3px solid #bb9af7;
		padding-left: calc(0.6rem - 3px);
	}

	.series-nav-item.is-upcoming {
		opacity: 0.45;
	}

	.series-nav-item-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.5rem;
		height: 1.5rem;
		flex-shrink: 0;
		border-radius: 50%;
		font-size: 0.7rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		background: rgba(86, 95, 137, 0.2);
		color: #a9b1d6;
	}

	.is-current .series-nav-item-num {
		background: rgba(187, 154, 247, 0.25);
		color: #bb9af7;
	}

	.series-nav-item-title {
		font-size: 0.85rem;
		color: #a9b1d6;
		text-decoration: none;
		line-height: 1.5;
		transition: color 0.15s ease;
	}

	a.series-nav-item-title:hover {
		color: #7aa2f7;
	}

	.series-nav-item-title.is-active {
		color: #c0caf5;
		font-weight: 600;
	}

	.series-nav-item-title.is-placeholder {
		font-style: italic;
		color: #565f89;
	}

	/* ─── Footer (prev / next) ─── */
	.series-nav-footer {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 0.85rem;
		border-top: 1px solid rgba(86, 95, 137, 0.15);
	}

	.series-nav-btn {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		max-width: 48%;
		transition: color 0.15s ease;
	}

	.series-nav-btn svg {
		flex-shrink: 0;
		color: #565f89;
		transition: color 0.15s ease;
	}

	.series-nav-btn:hover svg {
		color: #7aa2f7;
	}

	.series-nav-btn-label {
		display: flex;
		flex-direction: column;
	}

	.series-nav-btn-hint {
		font-size: 0.65rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: #565f89;
	}

	.series-nav-btn-title {
		font-size: 0.8rem;
		color: #a9b1d6;
		line-height: 1.35;
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
		transition: color 0.15s ease;
	}

	.series-nav-btn:hover .series-nav-btn-title {
		color: #7aa2f7;
	}

	.series-nav-next {
		margin-left: auto;
		text-align: right;
	}

	/* ─── Responsive ─── */
	@media (max-width: 640px) {
		.series-nav {
			padding: 1rem 1rem;
			border-radius: 12px;
		}

		.series-nav-title {
			font-size: 1rem;
		}

		.series-nav-footer {
			flex-direction: column;
			gap: 0.75rem;
		}

		.series-nav-btn {
			max-width: 100%;
		}

		.series-nav-next {
			margin-left: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.series-nav-progress-fill,
		.series-nav-chevron {
			transition: none;
		}
	}
</style>
