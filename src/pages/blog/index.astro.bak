---
import { Image } from "astro:assets";
import { type CollectionEntry, getCollection } from "astro:content";
import BaseHead from "@astro/base/BaseHead.astro";
import Footer from "@astro/footer/Footer.astro";
import Header from "@astro/header/Header.astro";
import { featureFlags } from "@config/featureFlag/featureFlag.json";
import authorConfig from "@config/siteConfig/info.json";

export const prerender = false;

const postsPerPage = 9;

const allPosts = (await getCollection("blog"))
	.filter(
		(post: CollectionEntry<"blog">) => !post.data.draft && !post.data.archived,
	)
	.sort(
		(a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
			b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);

const totalPosts = allPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);

const currentPage = 1;

const posts: CollectionEntry<"blog">[] = allPosts.slice(0, postsPerPage);
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const remainingPosts = featuredPost
	? posts.filter((post) => post !== featuredPost)
	: [];

const tagCounts = new Map();
for (const post of allPosts) {
	for (const tag of post.data.tags || []) {
		tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
	}
}

const topTags = Array.from(tagCounts.entries())
	.sort((a, b) => b[1] - a[1])
	.slice(0, 5)
	.map(([tag]) => tag);

const latestPostDate = allPosts[0]?.data.pubDate;
const latestPostLabel = latestPostDate
	? new Date(latestPostDate).toLocaleDateString("en-US", {
			month: "short",
			day: "numeric",
			year: "numeric",
		})
	: "—";

const formatDate = (date: Date) =>
	new Date(date).toLocaleDateString("en-US", {
		month: "short",
		day: "numeric",
		year: "numeric",
	});

const showTags = featureFlags.showTags;
const showSearch = featureFlags.showSearch;

try {
	if (!featureFlags.showBlog) {
		return Astro.redirect("/access-denied");
	}
} catch (_error) {
	return Astro.redirect("/404");
}
---

<html lang="en">
  <head>
    <BaseHead
      title={`Articles | ${authorConfig.SiteName}`}
      description={`Browse all articles on ${authorConfig.SiteName} and explore categorized content.`}
    />

    <style is:inline>
      html {
        background-color: #1a1b26 !important;
      }
      body {
        background-color: #1a1b26 !important;
      }
      #__astro {
        background-color: #1a1b26 !important;
      }
    </style>

    <style>
      /* Prevent white flash */
      html {
        background-color: #1a1b26 !important;
      }

      body {
        background-color: #1a1b26 !important;
        transition: none !important;
      }
    </style>

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Blog",
        name: `${authorConfig.SiteName} Blog`,
        description: `Browse all articles on ${authorConfig.SiteName} and explore categorized content.`,
        url: "https://rafay99.com/blog",
        publisher: {
          "@type": "Organization",
          name: authorConfig.SiteName,
          logo: {
            "@type": "ImageObject",
            url: "https://rafay99.com/favicon.webp",
          },
        },
        blogPost: posts.map(
          (post: CollectionEntry<"blog">, _index: number) => ({
            "@type": "BlogPosting",
            headline: post.data.title,
            description: post.data.description,
            author: {
              "@type": "Person",
              name: post.data.authorName,
            },
            datePublished: post.data.pubDate.toISOString(),
            url: `https://rafay99.com/blog/${post.slug}`,
            keywords: post.data.tags?.join(", ") || "blog, technology",
          }),
        ),
      })}
    />
  </head>
  <body class="flex min-h-screen flex-col bg-[#1a1b26] text-[#a9b1d6]">
    <Header />

    <main class="feed-shell mx-auto w-full max-w-3xl flex-1 px-5 pb-24 pt-14 sm:px-6">

      <!-- ─── Minimal Hero ─── -->
      <header class="feed-hero fade-up">
        <h1 class="feed-title">Articles, deep dives, and build notes.</h1>
        <p class="feed-sub">
          A curated stream of engineering stories, product explorations, and
          opinionated guides. Written with clarity, built for people who ship.
        </p>
        <div class="feed-meta-bar fade-up delay-1">
          <span class="meta-stat">{totalPosts} articles</span>
          <span class="meta-dot">&middot;</span>
          <span class="meta-stat">{tagCounts.size} topics</span>
          <span class="meta-dot">&middot;</span>
          <span class="meta-stat">Latest {latestPostLabel}</span>
          <span class="meta-dot meta-dot--actions">&middot;</span>
          <div class="meta-actions">
            <a href="/blog/archive" class="meta-link">Archive</a>
            {showSearch && <a href="/search" class="meta-link">Search</a>}
            {showTags && <a href="/tag" class="meta-link">Tags</a>}
          </div>
        </div>
        {
          showTags && topTags.length > 0 && (
            <div class="tag-rail fade-up delay-2">
              {topTags.map((tag) => (
                <a
                  href={`/tag/${encodeURIComponent(tag)}`}
                  class="tag-pill"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )
        }
      </header>

      {posts.length === 0 && (
        <div class="empty-state">
          <p>No published articles yet. Check back soon.</p>
        </div>
      )}

      <!-- ─── Featured Post ─── -->
      {
        featuredPost && (
          <a href={`/blog/${featuredPost.slug}`} class="featured-card group fade-up delay-1">
            <div class="featured-image-wrap">
              {featuredPost.data.heroImage ? (
                <Image
                  src={featuredPost.data.heroImage}
                  alt={featuredPost.data.title}
                  width={720}
                  height={400}
                  loading="eager"
                  decoding="async"
                  class="featured-img"
                />
              ) : (
                <div class="featured-fallback" aria-hidden="true" />
              )}
            </div>
            <div class="featured-body">
              <span class="featured-kicker">Featured</span>
              <h2 class="featured-title">{featuredPost.data.title}</h2>
              <p class="featured-excerpt line-clamp-2">
                {featuredPost.data.excerpt || featuredPost.data.description}
              </p>
              <div class="featured-footer">
                <span class="featured-date">{formatDate(featuredPost.data.pubDate)}</span>
                {featuredPost.data.tags?.[0] && (
                  <span class="featured-tag">#{featuredPost.data.tags[0]}</span>
                )}
                <span class="featured-cta">
                  Read story <span class="cta-arrow">&rarr;</span>
                </span>
              </div>
            </div>
          </a>
        )
      }

      <!-- ─── Article Feed ─── -->
      {
        remainingPosts.length > 0 && (
          <section class="feed-list">
            {remainingPosts.map((post, index) => (
              <a
                href={`/blog/${post.slug}`}
                class:list={["feed-item group", `fade-up delay-${Math.min(index + 1, 4)}`]}
              >
                <div class="feed-item-thumb">
                  {post.data.heroImage ? (
                    <Image
                      src={post.data.heroImage}
                      alt={post.data.title}
                      width={160}
                      height={160}
                      loading="lazy"
                      decoding="async"
                      class="feed-item-img"
                    />
                  ) : (
                    <div class="feed-item-fallback" aria-hidden="true" />
                  )}
                </div>
                <div class="feed-item-body">
                  <div class="feed-item-meta">
                    <span>{formatDate(post.data.pubDate)}</span>
                    {post.data.readTime && (
                      <>
                        <span class="meta-dot">&middot;</span>
                        <span>{post.data.readTime}</span>
                      </>
                    )}
                    {post.data.tags?.[0] && (
                      <>
                        <span class="meta-dot">&middot;</span>
                        <span class="feed-item-tag">#{post.data.tags[0]}</span>
                      </>
                    )}
                  </div>
                  <h3 class="feed-item-title line-clamp-2">{post.data.title}</h3>
                  <p class="feed-item-excerpt line-clamp-2">
                    {post.data.excerpt || post.data.description}
                  </p>
                </div>
              </a>
            ))}
          </section>
        )
      }

      <!-- ─── Pagination ─── -->
      {
        totalPages > 1 && (
          <nav class="pagination" aria-label="Pagination">
            <a
              href={currentPage > 1 ? `/blog/page/${currentPage - 1}` : "#"}
              class:list={[
                "pagination-link",
                currentPage > 1 ? "pagination-active" : "pagination-disabled",
              ]}
            >
              <span>&larr; Previous</span>
            </a>
            <div class="pagination-pill">
              {currentPage} / {totalPages}
            </div>
            <a
              href={
                currentPage < totalPages ? `/blog/page/${currentPage + 1}` : "#"
              }
              class:list={[
                "pagination-link",
                currentPage < totalPages
                  ? "pagination-active"
                  : "pagination-disabled",
              ]}
            >
              <span>Next &rarr;</span>
            </a>
          </nav>
        )
      }
    </main>

    <Footer />

    <style>
      /* ═══════════════════════════════════════════
         Clean Feed — Substack / Medium inspired
         ═══════════════════════════════════════════ */

      .feed-shell {
        position: relative;
        isolation: isolate;
      }

      /* ─── Hero ─── */
      .feed-hero {
        padding-bottom: 2rem;
        border-bottom: 1px solid rgba(86, 95, 137, 0.25);
        margin-bottom: 2.5rem;
      }

      .feed-title {
        font-size: clamp(2rem, 3vw + 1rem, 3.2rem);
        font-weight: 700;
        line-height: 1.1;
        color: #f8f8ff;
        letter-spacing: -0.02em;
      }

      .feed-sub {
        margin-top: 0.85rem;
        font-size: 1.05rem;
        line-height: 1.6;
        color: var(--color-text-secondary, #a9b1d6);
        max-width: 38rem;
      }

      .feed-meta-bar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1.25rem;
        font-size: 0.85rem;
      }

      .meta-stat {
        color: var(--color-text-muted, #565f89);
      }

      .meta-dot {
        color: rgba(86, 95, 137, 0.5);
      }

      .meta-actions {
        display: flex;
        gap: 0.75rem;
      }

      .meta-link {
        color: #7aa2f7;
        font-weight: 500;
        transition: color 0.2s ease;
      }

      .meta-link:hover {
        color: #bb9af7;
      }

      .tag-rail {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-top: 1.1rem;
      }

      .tag-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.2rem 0.65rem;
        border-radius: 999px;
        border: 1px solid rgba(86, 95, 137, 0.4);
        font-size: 0.75rem;
        color: var(--color-text-secondary, #a9b1d6);
        background: rgba(36, 40, 59, 0.5);
        transition:
          border-color 0.25s ease,
          color 0.25s ease;
      }

      .tag-pill:hover {
        border-color: rgba(122, 162, 247, 0.6);
        color: #dbe2ff;
      }

      /* ─── Featured Card ─── */
      .featured-card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        border-radius: 20px;
        border: 1px solid rgba(86, 95, 137, 0.3);
        background: rgba(36, 40, 59, 0.5);
        overflow: hidden;
        margin-bottom: 2rem;
        transition:
          border-color 0.3s ease,
          box-shadow 0.3s ease,
          transform 0.3s ease;
      }

      .featured-card:hover {
        border-color: rgba(122, 162, 247, 0.55);
        box-shadow: 0 16px 40px rgba(10, 12, 22, 0.4);
        transform: translateY(-2px);
      }

      .featured-image-wrap {
        position: relative;
        overflow: hidden;
        min-height: 240px;
      }

      .featured-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
      }

      .featured-card:hover .featured-img {
        transform: scale(1.03);
      }

      .featured-fallback {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(36, 40, 59, 0.9), rgba(122, 162, 247, 0.3));
      }

      .featured-body {
        padding: 1.6rem 1.8rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.6rem;
      }

      .featured-kicker {
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #7aa2f7;
        font-weight: 600;
      }

      .featured-title {
        font-size: clamp(1.25rem, 1.5vw + 0.8rem, 1.75rem);
        font-weight: 700;
        line-height: 1.25;
        color: #f1f1ff;
      }

      .featured-excerpt {
        font-size: 0.9rem;
        color: var(--color-text-secondary, #a9b1d6);
        line-height: 1.5;
      }

      .featured-footer {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.3rem;
        font-size: 0.78rem;
      }

      .featured-date {
        color: var(--color-text-muted, #565f89);
      }

      .featured-tag {
        color: var(--color-text-muted, #565f89);
      }

      .featured-cta {
        margin-left: auto;
        color: #7aa2f7;
        font-weight: 600;
        font-size: 0.85rem;
      }

      .cta-arrow {
        display: inline-block;
        transition: transform 0.25s ease;
      }

      .featured-card:hover .cta-arrow {
        transform: translateX(3px);
      }

      /* ─── Feed List ─── */
      .feed-list {
        display: flex;
        flex-direction: column;
      }

      .feed-item {
        display: grid;
        grid-template-columns: 88px 1fr;
        gap: 1.1rem;
        padding: 1.35rem 0;
        border-bottom: 1px solid rgba(86, 95, 137, 0.18);
        transition:
          background-color 0.25s ease;
      }

      .feed-item:first-child {
        border-top: 1px solid rgba(86, 95, 137, 0.18);
      }

      .feed-item:hover {
        background-color: rgba(36, 40, 59, 0.3);
      }

      .feed-item-thumb {
        width: 88px;
        height: 88px;
        border-radius: 12px;
        overflow: hidden;
        flex-shrink: 0;
        background: rgba(36, 40, 59, 0.6);
      }

      .feed-item-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
      }

      .feed-item:hover .feed-item-img {
        transform: scale(1.06);
      }

      .feed-item-fallback {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(36, 40, 59, 0.9), rgba(122, 162, 247, 0.3));
      }

      .feed-item-body {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.3rem;
        min-width: 0;
      }

      .feed-item-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.75rem;
        color: var(--color-text-muted, #565f89);
      }

      .feed-item-tag {
        color: #7aa2f7;
      }

      .feed-item-title {
        font-size: 1.08rem;
        font-weight: 600;
        line-height: 1.35;
        color: var(--color-text-primary, #c0caf5);
        transition: color 0.2s ease;
      }

      .feed-item:hover .feed-item-title {
        color: #f1f1ff;
      }

      .feed-item-excerpt {
        font-size: 0.88rem;
        color: var(--color-text-secondary, #a9b1d6);
        line-height: 1.5;
      }

      /* ─── Pagination ─── */
      .pagination {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(86, 95, 137, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
      }

      .pagination-link {
        padding: 0.45rem 1.1rem;
        border-radius: 999px;
        border: 1px solid rgba(86, 95, 137, 0.35);
        font-size: 0.85rem;
        font-weight: 500;
        transition:
          border-color 0.25s ease,
          color 0.25s ease;
      }

      .pagination-active {
        color: #7aa2f7;
      }

      .pagination-active:hover {
        border-color: rgba(122, 162, 247, 0.6);
        color: #bb9af7;
      }

      .pagination-disabled {
        color: rgba(86, 95, 137, 0.5);
        cursor: not-allowed;
      }

      .pagination-pill {
        font-size: 0.8rem;
        color: var(--color-text-muted, #565f89);
        font-variant-numeric: tabular-nums;
      }

      /* ─── Empty State ─── */
      .empty-state {
        margin-top: 2.5rem;
        padding: 1.5rem;
        border-radius: 16px;
        border: 1px dashed rgba(86, 95, 137, 0.4);
        text-align: center;
        color: var(--color-text-secondary, #a9b1d6);
      }

      /* ─── Utilities ─── */
      .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* ─── Animations ─── */
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .fade-up {
        animation: fadeUp 0.6s ease both;
      }

      .delay-1 {
        animation-delay: 0.08s;
      }

      .delay-2 {
        animation-delay: 0.16s;
      }

      .delay-3 {
        animation-delay: 0.24s;
      }

      .delay-4 {
        animation-delay: 0.32s;
      }

      /* ─── Responsive ─── */
      @media (max-width: 640px) {
        .featured-card {
          grid-template-columns: 1fr;
        }

        .featured-image-wrap {
          min-height: 200px;
          max-height: 220px;
        }

        .featured-body {
          padding: 1.2rem 1.4rem 1.4rem;
        }

        .feed-item {
          grid-template-columns: 68px 1fr;
          gap: 0.85rem;
          padding: 1.1rem 0;
        }

        .feed-item-thumb {
          width: 68px;
          height: 68px;
          border-radius: 10px;
        }

        .feed-item-title {
          font-size: 0.98rem;
        }

        .feed-item-excerpt {
          display: none;
        }

        .meta-dot--actions {
          display: none;
        }

        .meta-actions {
          width: 100%;
          margin-top: 0.25rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .fade-up {
          animation: none;
        }

        .featured-card,
        .feed-item,
        .tag-pill,
        .pagination-link {
          transition: none;
        }
      }
    </style>
  </body>
</html>
